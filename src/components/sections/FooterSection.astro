---
import { SOCIAL } from "@/lib/constants";

const LINKS = [
  {
    name: "linkedin",
    href: SOCIAL.LINKEDIN,
  },
  {
    name: "github",
    href: SOCIAL.GITHUB,
  },
] as const;
---

<footer class="bg-light-primary">
  <div class="max-w-10/12 mx-auto">
    <div class="h-48 flex items-center justify-between">
      <div class="space-x-16">
        {
          LINKS.map((l) => (
            <a
              href={l.href}
              target="_blank"
              class="text-dark-tertiary uppercase"
            >
              {l.name}
            </a>
          ))
        }
      </div>
      <p class="text-dark-tertiary">
        {new Date().getFullYear()} Cristian Viveros
      </p>
    </div>
  </div>
</footer>
