---
import { SECTION, SOCIAL } from "@/lib/constants";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const PROJECT_TYPES = [
  { value: "", label: "Selecciona el tipo de proyecto" },
  { value: "mvp", label: "MVP / Startup" },
  { value: "web", label: "Aplicación web" },
  { value: "mobile", label: "Mobile app" },
  { value: "backend", label: "Backend / API" },
  { value: "scale", label: "Escalabilidad / arquitectura" },
  { value: "freelance", label: "Proyecto freelance" },
  { value: "otro", label: "Otro" },
] as const;
---

<section
  id={SECTION.CONTACT}
  class:list={[
    "py-24 min-h-[80vh] w-full bg-secondary animate-fade-in",
    className,
  ]}
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid xl:grid-cols-2 gap-12 md:gap-24">
      <!-- Lado Izquierdo: Texto -->
      <div class="space-y-8 text-left">
        <h2
          class="text-5xl md:text-6xl lg:text-7xl font-bold text-primary leading-tight text-left"
        >
          Construyamos algo que pueda crecer.
        </h2>

        <p class="text-lg md:text-xl text-tertiary leading-relaxed max-w-xl">
          Trabajo con startups, empresas y clientes freelance para diseñar y
          construir productos digitales rápidos, escalables y listos para
          producción. Desde MVPs hasta arquitecturas pensadas para alto tráfico.
        </p>

        <p class="text-base text-tertiary/80">
          Disponible para colaboraciones remotas y proyectos freelance.
        </p>
      </div>

      <!-- Lado Derecho: Formulario -->
      <form
        class="space-y-6"
        onsubmit="event.preventDefault(); console.log('Form submitted');"
      >
        <div>
          <label for="name" class="sr-only">Nombre</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Tu nombre"
            required
            class="w-full border border-tertiary/20 bg-secondary focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors duration-300 px-6 py-4 placeholder:text-tertiary/50"
          />
        </div>

        <div>
          <label for="email" class="sr-only">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="tu@email.com"
            required
            class="w-full border border-tertiary/20 bg-secondary focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors duration-300 px-6 py-4 placeholder:text-tertiary/50"
          />
        </div>

        <div>
          <label for="project-type" class="sr-only">Tipo de proyecto</label>
          <select
            id="project-type"
            name="project-type"
            required
            class="w-full border border-tertiary/20 bg-secondary focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors duration-300 px-6 py-4 placeholder:text-tertiary/50 appearance-none cursor-pointer"
          >
            {
              PROJECT_TYPES.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))
            }
          </select>
        </div>

        <div>
          <label for="message" class="sr-only">Mensaje</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder="Cuéntame qué estás construyendo o qué necesitas resolver"
            required
            class="w-full border border-tertiary/20 bg-secondary focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors duration-300 px-6 py-4 placeholder:text-tertiary/50 resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="hover-btn hover-btn--accent w-full py-4 font-semibold text-accent border border-accent bg-transparent transition-all duration-300 hover:text-secondary cursor-pointer"
        >
          Hablemos
        </button>

        <!-- Links sociales alternativos -->
        <div class="pt-4 text-center">
          <p class="text-sm text-tertiary/70 mb-3">
            Prefieres contacto directo?
          </p>
          <div class="flex items-center justify-center gap-6">
            <a
              href={SOCIAL.LINKEDIN}
              target="_blank"
              rel="noopener noreferrer"
              class="underline-hover text-sm text-tertiary hover:text-accent transition-colors duration-300"
            >
              LinkedIn
            </a>
            <a
              href={SOCIAL.GITHUB}
              target="_blank"
              rel="noopener noreferrer"
              class="underline-hover text-sm text-tertiary hover:text-accent transition-colors duration-300"
            >
              GitHub
            </a>
            <a
              href={`mailto:${SOCIAL.EMAIL}`}
              class="underline-hover text-sm text-tertiary hover:text-accent transition-colors duration-300"
            >
              Email
            </a>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>
